{
  "title": "Agentic AI + LLM Gateway",
  "uid": "agentic-ai-dashboard",
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "tags": [
    "agentic-ai",
    "llm",
    "gateway"
  ],
  "panels": [
    {
      "id": 1,
      "title": "\ud83d\udea6 Pipeline Status Overview",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(agentic_gateway_requests_total[5m]))",
          "legendFormat": "Req/sec"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 2,
      "title": "\u26a1 Active Pipelines",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "agentic_active_pipelines",
          "legendFormat": "Active"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "title": "\ud83d\udcbe Cache Hit Rate",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(agentic_gateway_cache_hits_total[5m])) / sum(rate(agentic_gateway_requests_total[5m])) * 100",
          "legendFormat": "Cache Hit %"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "unit": "percent",
        "thresholds": {
          "steps": [
            {
              "color": "red",
              "value": 0
            },
            {
              "color": "yellow",
              "value": 20
            },
            {
              "color": "green",
              "value": 40
            }
          ]
        }
      }
    },
    {
      "id": 4,
      "title": "\ud83d\udee1\ufe0f Guardrail Violations",
      "type": "stat",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(agentic_guardrails_violations_total[1h]))",
          "legendFormat": "Violations (1h)"
        }
      ],
      "options": {
        "colorMode": "value"
      }
    },
    {
      "id": 5,
      "title": "\u23f1\ufe0f LLM Latency by Agent (P95)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum by (agent, le) (rate(agentic_llm_latency_seconds_bucket[5m])))",
          "legendFormat": "{{agent}} p95"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.50, sum by (agent, le) (rate(agentic_llm_latency_seconds_bucket[5m])))",
          "legendFormat": "{{agent}} p50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 6,
      "title": "\ud83e\ude99 Token Usage by Agent",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (agent, type) (rate(agentic_gateway_tokens_total[5m]))",
          "legendFormat": "{{agent}} / {{type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 7,
      "title": "\ud83d\udcca RAGAS Evaluation Scores",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.5, rate(agentic_ragas_faithfulness_bucket[10m]))",
          "legendFormat": "Faithfulness (p50)"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.5, rate(agentic_ragas_answer_relevancy_bucket[10m]))",
          "legendFormat": "Answer Relevancy (p50)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 0.6
              },
              {
                "color": "green",
                "value": 0.8
              }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "\ud83d\udd27 Tool Call Rate",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (tool_name, status) (rate(agentic_tool_calls_total[5m]))",
          "legendFormat": "{{tool_name}} / {{status}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "\ud83d\udcdd Application Logs",
      "type": "logs",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 24,
        "h": 10
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{service=\"agentic-app\"} | json | level=~\"(info|warn|error)\"",
          "legendFormat": ""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "enableLogDetails": true,
        "wrapLogMessage": true
      }
    },
    {
      "id": 10,
      "title": "\ud83d\udea8 Guardrail Violations by Type",
      "type": "piechart",
      "gridPos": {
        "x": 0,
        "y": 30,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (violation_type) (increase(agentic_guardrails_violations_total[1h]))",
          "legendFormat": "{{violation_type}}"
        }
      ]
    },
    {
      "id": 11,
      "title": "\ud83d\udcc8 Pipeline Duration Distribution",
      "type": "histogram",
      "gridPos": {
        "x": 12,
        "y": 30,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (le) (rate(agentic_pipeline_duration_seconds_bucket[5m]))",
          "legendFormat": "{{le}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 12,
      "title": "\ud83d\udcb0 Estimated Cost per Agent (USD/min)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 38,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (agent) (rate(agentic_gateway_cost_usd_total[5m])) * 60",
          "legendFormat": "{{agent}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 13,
      "title": "\ud83d\udcb0 Cumulative Cost by Model (USD)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 38,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (model) (agentic_gateway_cost_usd_total)",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 14,
      "title": "\ud83d\udcb0 Cache Savings (tokens NOT sent to LLM)",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 46,
        "w": 12,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(agentic_gateway_cache_hits_total)",
          "legendFormat": "Cache Hits (each = ~$0.001 saved)"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      }
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "timezone": "browser"
}