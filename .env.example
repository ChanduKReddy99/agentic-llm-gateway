# =============================================================
# Agentic AI + LLM Gateway — Environment Configuration
# =============================================================
# Copy this to .env and fill in your values:
#   cp .env.example .env

# ============== LLM Provider API Keys ===========================================
# Minimum: set OPENAI_API_KEY. Others are used for fallback chain.
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GROQ_API_KEY=gsk_your-groq-key-here          # Free tier — get at console.groq.com
TAVILY_API_KEY=tvly-your-tavily-key-here      # Get at app.tavily.com

# ==== LiteLLM Proxy =================================================
LITELLM_PROXY_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-litellm-master-key-1234
LITELLM_SALT_KEY=sk-salt-key-5678

# ==== Redis ====================================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ====== Langfuse (local Docker) ====================================
# These keys are AUTO-CREATED by docker-compose on first boot.
# docker-compose sets: LANGFUSE_INIT_PROJECT_PUBLIC_KEY and
#                      LANGFUSE_INIT_PROJECT_SECRET_KEY
# So these values already match — no manual UI setup needed.
#
# UI login: http://localhost:3001
# Email:    admin@example.com
# Password: password
LANGFUSE_PUBLIC_KEY=pk-lf-agentic-local-public
LANGFUSE_SECRET_KEY=sk-lf-agentic-local-secret
LANGFUSE_HOST=http://localhost:3001

# ===== Application ===========================================
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ===== Loki (direct push from app — no Promtail needed) ========================
LOKI_URL=http://localhost:3100

# ==== OpenTelemetry → Tempo ====================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=agentic-ai-app
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=development

# ============= Prometheus =================================
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus_multiproc

# =========== Langfuse Database (used by docker-compose internally) ================
LANGFUSE_DATABASE_URL=postgresql://langfuse:langfuse@localhost:5432/langfuse

# ===== GitHub Actions Secrets =====================================================
# For the CI/CD prompt workflows to work, add these to your
# GitHub repo → Settings → Secrets → Actions:
#
#   LANGFUSE_PUBLIC_KEY  = pk-lf-agentic-local-public
#   LANGFUSE_SECRET_KEY  = sk-lf-agentic-local-secret
#   LANGFUSE_HOST        = https://your-langfuse-host.com  (cloud) or
#                          http://your-server-ip:3001       (self-hosted)
#   OPENAI_API_KEY       = sk-...  (needed for ragas-eval workflow)
#
# For local Docker Langfuse, LANGFUSE_HOST must be publicly
# reachable by GitHub Actions — use ngrok or self-hosted runner.
